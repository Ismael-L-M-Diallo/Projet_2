<!DOCTYPE html>
<html>
<body>
    <h1>Mini Reddit</h1>

    <% if (!idConnecte) { %>
        <h2>Inscription</h2>
        <form action="/users/inscription" method="POST">
            <input type="text" name="pseudo" placeholder="Pseudo" required>
            <input type="password" name="motDePasse" placeholder="Mot de passe" required>
            <button type="submit">S'inscrire</button>
        </form>

        <h2>Connexion</h2>
        <form action="/users/connexion" method="POST">
            <input type="text" name="pseudo" placeholder="Pseudo" required>
            <input type="password" name="motDePasse" placeholder="Mot de passe" required>
            <button type="submit">Se connecter</button>
        </form>

    <% } else { %>
        <p> Vous êtes connecté. <a href="/users/deconnexion">Se déconnecter</a></p>
        
        <h2>Nouveau Post</h2>
        <form action="/posts/ajout" method="POST">
            <input type="text" name="titre" placeholder="Titre" required>
            <input type="text" name="contenu" placeholder="Contenu" required>
            <button type="submit">Publier</button>
        </form>
    <% } %>

    <hr>
    <h2>Fil d'actualité</h2>
    
    <form action="/" method="GET" style="margin-bottom: 20px;">
        Filtrer par auteur: 
        <select name="auteurId">
            <option value="">Tous les auteurs</option>
            <% users.forEach(user => { %>
                <option value="<%= user._id %>" <%= filtreActuel == user._id ? 'selected' : '' %>>
                    <%= user.pseudo %>
                </option>
            <% }) %>
        </select>
        <button type="submit">Filtrer</button>
    </form>

    <ul>
        <% posts.forEach(post => { %>
            <li style="margin-bottom: 15px;">
                <strong><%= post.titre %></strong> 
                (par <%= post.auteur ? post.auteur.pseudo : 'Inconnu' %>) 
                - Votes : <%= post.votes %>
                
                <p><%= post.contenu %></p>
                
                <% if (typeof utilisateurConnecte !== 'undefined' && utilisateurConnecte) { %>
                    
                    <form action="/posts/upvote/<%= post._id %>" method="POST" style="display:inline;">
                        <input type="hidden" name="votantId" value="<%= utilisateurConnecte._id %>">
                        
                        <button type="submit">⬆️ Upvote</button>
                    </form>

                <% } %>

                <% if (idConnecte && post.auteur && idConnecte == post.auteur._id.toString()) { %>
                    <form action="/posts/modifier/<%= post._id %>" method="POST" style="display:inline;">
                        <input type="text" name="nouveauContenu" placeholder="Modifier le texte" required>
                        <button type="submit">Modifier</button>
                    </form>

                    <form action="/posts/supprimer/<%= post._id %>" method="POST" style="display:inline;">
                        <button type="submit">Supprimer</button>
                    </form>
                <% } %>
            </li>
        <% }) %>
    </ul>
</body>
</html>