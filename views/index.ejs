<!DOCTYPE html>
<html lang="fr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>ConnectHub</title>
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="style.css">

</head>
<body>

    <nav class="navbar navbar-expand-lg navbar-dark sticky-top">
        <div class="container-fluid">
            <a class="navbar-brand" href="#">🪐 ConnectHub</a>
            <button class="navbar-toggler" type="button" data-bs-toggle="collapse" data-bs-target="#navbarNav">
                <span class="navbar-toggler-icon"></span>
            </button>
            <div class="collapse navbar-collapse" id="navbarNav">
                <ul class="navbar-nav me-auto">
                    <li class="nav-item"><a class="nav-link" href="#posts">Posts</a></li>
                    <li class="nav-item">
                        <a class="nav-link" href="#" data-bs-toggle="offcanvas" data-bs-target="#chatOffcanvas">💬 Chat</a>
                    </li>
                </ul>
                <% if (!idConnecte) { %>
                    <a class="nav-link" href="#auth">🔐 Connexion</a>
                <% } else { %>
                    <span class="navbar-text me-3 text-light">👋 Connecté</span>
                    <a class="nav-link" href="/users/deconnexion">🚪 Déconnexion</a>
                <% } %>
            </div>
        </div>
    </nav>

    <div class="container-fluid mt-4">

        <!-- AUTH -->
        <% if (!idConnecte) { %>
        <div id="auth" class="row mb-5">
            <div class="col-md-6">
                <div class="section-card">
                    <h3>👤 Inscription</h3>
                    <form action="/users/inscription" method="POST">
                        <input type="text" name="pseudo" class="form-control mb-3" placeholder="Pseudo" required>
                        <input type="password" name="motDePasse" class="form-control mb-3" placeholder="Mot de passe" required>
                        <button type="submit" class="btn btn-success btn-modern">S'inscrire</button>
                    </form>
                </div>
            </div>
            <div class="col-md-6">
                <div class="section-card">
                    <h3>🔑 Connexion</h3>
                    <form action="/users/connexion" method="POST">
                        <input type="text" name="pseudo" class="form-control mb-3" placeholder="Pseudo" required>
                        <input type="password" name="motDePasse" class="form-control mb-3" placeholder="Mot de passe" required>
                        <button type="submit" class="btn btn-primary btn-modern">Se connecter</button>
                    </form>
                </div>
            </div>
        </div>
        <% } %>

        <!-- POSTS -->
        <div id="posts" class="row mb-5">
            <div class="col-12">
                <div class="section-card">
                    <div class="d-flex justify-content-between align-items-center mb-4 flex-wrap gap-2">
                        <h2>Posts</h2>
                        <% if (idConnecte) { %>
                            <form action="/posts/ajout" method="POST" class="d-flex gap-2">
                                <input type="text" name="titre" class="form-control" placeholder="Titre" required>
                                <input type="text" name="contenu" class="form-control" placeholder="Contenu" required>
                                <button type="submit" class="btn btn-success btn-modern">Publier</button>
                            </form>
                        <% } %>
                    </div>

                    <!-- FILTRE + TRI -->
                    <form action="/" method="GET" class="mb-4">
                        <div class="row g-2">
                            <div class="col-md-3">
                                <label class="form-label">Auteur :</label>
                                <select name="auteurId" class="form-select">
                                    <option value="">Tous</option>
                                    <% users.forEach(user => { %>
                                        <option value="<%= user._id %>" <%= filtreActuel == user._id ? 'selected' : '' %>>
                                            <%= user.pseudo %>
                                        </option>
                                    <% }) %>
                                </select>
                            </div>
                            <div class="col-md-3">
                                <label class="form-label">Trier par :</label>
                                <select name="sort" class="form-select">
                                    <option value="votes" selected>⬆️ Votes</option>
                                    <option value="dateCreation"> Date</option>
                                    <option value="titre">Titre</option>
                                </select>
                            </div>
                            <div class="col-md-2">
                                <label class="form-label">Ordre :</label>
                                <select name="order" class="form-select">
                                    <option value="desc" selected>Décroissant</option>
                                    <option value="asc">Croissant</option>
                                </select>
                            </div>
                            <div class="col-md-4 d-flex align-items-end">
                                <button type="submit" class="btn btn-outline-light btn-modern w-100">🔍 Filtrer / Trier</button>
                            </div>
                        </div>
                    </form>

                    <!-- LISTE POSTS -->
                    <div class="list-group">
                        <% posts.forEach(post => { %>
                            <div class="list-group-item bg-dark text-light mb-3 rounded">
                                <div class="d-flex justify-content-between">
                                    <h5><%= post.titre %></h5>
                                    <span class="badge bg-success fs-6"><%= post.votes %> votes</span>
                                </div>
                                <p class="mb-2"><%= post.contenu %></p>
                                <small>Par <%= post.auteur ? post.auteur.pseudo : 'Anonyme' %></small>
                                <% if (idConnecte) { %>
                                    <div class="mt-2 d-flex flex-wrap gap-2 align-items-center">
                                        <form action="/posts/upvote/<%= post._id %>" method="POST">
                                            <input type="hidden" name="votantId" value="<%= idConnecte %>">
                                            <button type="submit" class="btn btn-sm btn-success">⬆️ Upvote</button>
                                        </form>
                                        <% if (idConnecte == post.auteur._id.toString()) { %>
                                            <form action="/posts/modifier/<%= post._id %>" method="POST" class="d-flex gap-1">
                                                <input type="text" name="nouveauContenu" placeholder="Nouveau contenu" class="form-control form-control-sm">
                                                <button type="submit" class="btn btn-sm btn-warning">✏️</button>
                                            </form>
                                            <form action="/posts/supprimer/<%= post._id %>" method="POST">
                                                <button type="submit" class="btn btn-sm btn-danger" onclick="return confirm('Supprimer ?')">🗑️</button>
                                            </form>
                                        <% } %>
                                    </div>
                                <% } %>
                            </div>
                        <% }) %>
                    </div>
                </div>
            </div>
        </div>

        <!-- BOUTON CHAT -->
        <div class="row mb-3">
            <div class="col-12">
                <button class="btn btn-primary btn-modern" type="button" data-bs-toggle="offcanvas" data-bs-target="#chatOffcanvas">
                    💬 Ouvrir Chat Bot
                </button>
            </div>
        </div>

    </div>

    <!-- OFFCANVAS CHAT -->
    <div class="offcanvas offcanvas-end" tabindex="-1" id="chatOffcanvas">
        <div class="offcanvas-header">
            <h5 class="offcanvas-title">Chat ConnectBot</h5>
            <button type="button" class="btn-close btn-close-white" data-bs-dismiss="offcanvas"></button>
        </div>
        <div class="offcanvas-body">
            <div id="chat-messages" class="chat-messages mb-3"></div>
            <div class="input-group">
                <input type="text" id="chat-input" class="form-control" placeholder="Tapez un message...">
                <button class="btn btn-primary" id="send-chat">Envoyer</button>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.3/dist/js/bootstrap.bundle.min.js"></script>
    <script src="/socket.io/socket.io.js"></script>
    <script src="/app.js"></script>
</body>
</html>
